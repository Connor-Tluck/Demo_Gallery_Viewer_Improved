# Nearmap Demo Gallery - Environment Variables Template
#
# For this static HTML/JS app, API keys are configured in examples/keys.js
# (copy from examples/keys.js.example). This .env.example documents the keys
# needed if you add a build step or server-side components later.
#
# Required for mapping examples:
NEARMAP_API_KEY=your_nearmap_api_key
MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_token
GOOGLE_MAPS_API_KEY=AIzaSy_your_google_key
CESIUM_ION_ACCESS_TOKEN=eyJ_your_cesium_token
OPEN_AI_API_KEY=sk-proj-your_openai_api_key_here
