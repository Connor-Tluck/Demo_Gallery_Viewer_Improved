# Nearmap Demo Gallery - Environment Variables
#
# Keys are loaded in this order:
# 1. Netlify env vars (set in Netlify dashboard)
# 2. This .env file (local dev)
# 3. examples/keys.js (manual copy from keys.js.example)
#
# Run `npm run build` to generate keys.js from env vars.
# Netlify runs this automatically on deploy.
#
# Required for mapping examples:
NEARMAP_API_KEY=your_nearmap_api_key
MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_token
GOOGLE_MAPS_API_KEY=AIzaSy_your_google_key
CESIUM_ION_ACCESS_TOKEN=eyJ_your_cesium_token
