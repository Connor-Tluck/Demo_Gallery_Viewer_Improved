{
  "name": "nearmap-demo-gallery",
  "version": "1.0.0",
  "scripts": {
    "start": "npx serve -l 3000",
    "dev": "npx serve -l 3000",
    "build:keys": "node scripts/build-keys.js",
    "build:ld": "npx esbuild scripts/ld-entry.js --bundle --format=iife --outfile=files/ld-bundle.js --minify",
    "ld:convert": "node scripts/ld-convert-to-json-flags.js",
    "build": "npm run build:keys && npm run build:ld"
  },
  "devDependencies": {
    "dotenv": "^16.3.1",
    "esbuild": "^0.27.3",
    "netlify-cli": "^12.1.1"
  },
  "dependencies": {
    "@launchdarkly/observability": "^1.0.2",
    "@launchdarkly/session-replay": "^1.0.2",
    "launchdarkly-js-client-sdk": "^3.9.0"
  }
}
